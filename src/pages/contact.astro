---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="联系我们 - 星驿付">
  <Navbar />
  <main class="flex-grow pb-8">
    <div class="pt-20 min-h-screen bg-slate-50">
      <div class="bg-brand-800 py-16">
        <div class="max-w-7xl mx-auto px-4 text-center">
          <h1 class="text-3xl font-bold text-white mb-2">联系我们</h1>
          <p class="text-blue-200">无论是办理机器还是加盟代理，我们随时为您服务</p>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10 pb-20">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col md:flex-row">
          
          <!-- Info Side -->
          <div class="md:w-2/5 bg-slate-900 text-white p-10 flex flex-col justify-between">
            <div>
              <h3 class="text-2xl font-bold mb-8">联系方式</h3>
              <ul class="space-y-8">
                <li class="flex items-start gap-4">
                  <div class="bg-blue-600 p-3 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <div>
                    <p class="text-gray-400 text-sm">客服热线</p>
                    <p class="text-xl font-semibold">400-926-6655</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <div class="bg-blue-600 p-3 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <div>
                    <p class="text-gray-400 text-sm">商务合作</p>
                    <p class="text-lg">business@starpos.com</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <div class="bg-blue-600 p-3 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class="text-gray-400 text-sm">公司地址</p>
                    <p class="text-lg leading-snug">上海市浦东新区陆家嘴环路100号<br/>金融大厦28层</p>
                  </div>
                </li>
              </ul>
            </div>
            <div class="mt-12">
               <p class="text-gray-400 text-sm mb-4">关注我们的社交媒体</p>
               <div class="flex gap-4">
                 {[1,2,3].map(() => <div class="w-10 h-10 bg-slate-800 rounded-full hover:bg-blue-600 transition-colors cursor-pointer"></div>)}
               </div>
            </div>
          </div>

          <!-- Form Side -->
          <div class="md:w-3/5 p-10">
            <div id="contact-form-container">
              <form id="contact-form">
                <h3 class="text-2xl font-bold text-slate-900 mb-6">在线留言</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">您的姓名</label>
                    <input 
                      required
                      type="text" 
                      name="name"
                      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all"
                      placeholder="请输入姓名"
                    />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">联系电话</label>
                    <input 
                      required
                      type="tel" 
                      name="phone"
                      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all"
                      placeholder="请输入手机号"
                    />
                  </div>
                </div>
                
                <div class="mb-6">
                  <label class="block text-sm font-medium text-gray-700 mb-2">所在城市</label>
                  <input 
                    type="text" 
                    name="city"
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all"
                    placeholder="例如：上海"
                  />
                </div>

                <div class="mb-8">
                  <label class="block text-sm font-medium text-gray-700 mb-2">咨询类型</label>
                  <div class="grid grid-cols-2 gap-4">
                    <label class="type-label border rounded-lg p-3 flex items-center justify-center cursor-pointer transition-all border-brand-600 bg-brand-50 text-brand-700" data-type="handle">
                      <input type="radio" name="type" value="handle" class="hidden" checked />
                      <span>申请办理机器</span>
                    </label>
                    <label class="type-label border rounded-lg p-3 flex items-center justify-center cursor-pointer transition-all border-gray-200 hover:border-brand-300" data-type="join">
                      <input type="radio" name="type" value="join" class="hidden" />
                      <span>成为代理商</span>
                    </label>
                  </div>
                </div>

                <button type="submit" class="w-full bg-accent-500 text-white font-bold py-4 rounded-lg hover:bg-accent-600 transition-colors shadow-lg shadow-orange-200">
                  立即提交
                </button>
              </form>
            </div>

            <div id="success-message" class="hidden h-full flex flex-col items-center justify-center text-center">
              <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-2">提交成功！</h3>
              <p class="text-gray-600">我们的客户经理将在24小时内与您联系，请保持电话畅通。</p>
              <button id="reset-form" class="mt-8 text-brand-600 font-semibold hover:underline">返回</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('contact-form-container');
  const successMessage = document.getElementById('success-message');
  const resetBtn = document.getElementById('reset-form');
  const typeLabels = document.querySelectorAll('.type-label');

  typeLabels.forEach((label) => {
    label.addEventListener('click', () => {
      typeLabels.forEach((l) => {
        l.classList.remove('border-brand-600', 'bg-brand-50', 'text-brand-700');
        l.classList.add('border-gray-200', 'hover:border-brand-300');
      });
      label.classList.remove('border-gray-200', 'hover:border-brand-300');
      label.classList.add('border-brand-600', 'bg-brand-50', 'text-brand-700');
    });
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (formContainer) formContainer.classList.add('hidden');
    if (successMessage) successMessage.classList.remove('hidden');
  });

  resetBtn?.addEventListener('click', () => {
    if (formContainer) formContainer.classList.remove('hidden');
    if (successMessage) successMessage.classList.add('hidden');
    form?.reset();
  });
</script>
