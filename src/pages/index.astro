---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { PRODUCTS, STATS } from '../constants';
---

<Layout>
  <Navbar />
  <main class="flex-grow pb-8">
    <div class="min-h-screen">
      <!-- Hero Section -->
      <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 bg-brand-900 overflow-hidden">
        <!-- Background Decorative Elements -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blue-500 opacity-20 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-accent-500 opacity-10 blur-3xl"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-8 text-center lg:text-left">
              <h1 class="text-4xl lg:text-6xl font-extrabold text-white leading-tight">
                智慧支付 <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">
                  驱动商业未来
                </span>
              </h1>
              <p class="text-xl text-blue-100 max-w-2xl mx-auto lg:mx-0">
                星驿付为您提供全场景支付解决方案，不仅仅是收银，更是您生意增长的智能引擎。安全、稳定、高效。
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                <a href="/products" class="px-8 py-4 bg-accent-600 hover:bg-accent-700 text-white rounded-lg font-bold text-lg transition-all shadow-lg shadow-orange-900/20 flex items-center justify-center gap-2">
                  立即申请 
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/solutions" class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/20 rounded-lg font-bold text-lg transition-all flex items-center justify-center">
                  了解方案
                </a>
              </div>
            </div>
            
            <div class="relative hidden lg:block">
              <img 
                src="/img/支付场景.png" 
                alt="星驿付 Device" 
                class="rounded-xl shadow-2xl transform rotate-3 hover:rotate-0 transition-transform duration-700 border-4 border-white/10"
              />
              <!-- Floating Cards -->
              <div class="absolute -bottom-10 -left-10 bg-white p-4 rounded-lg shadow-xl animate-bounce" style="animation-duration: 3s;">
                <div class="flex items-center gap-3">
                  <div class="p-2 bg-green-100 rounded-full text-green-600">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">安全认证</p>
                    <p class="font-bold text-slate-900">银联检测通过</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Stats Bar -->
      <div class="bg-white shadow-lg relative z-20 -mt-10 mx-4 lg:mx-auto max-w-7xl rounded-xl p-8 grid grid-cols-2 lg:grid-cols-4 gap-8 divide-x divide-gray-100">
        {STATS.map((stat) => (
          <div class="text-center px-4">
            <p class="text-4xl font-bold text-brand-800 mb-1">{stat.value}<span class="text-lg text-gray-500 ml-1">{stat.suffix}</span></p>
            <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">{stat.label}</p>
          </div>
        ))}
      </div>

      <!-- Features Grid -->
      <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-brand-600 font-semibold tracking-wide uppercase text-sm mb-3">核心优势</h2>
            <h3 class="text-3xl font-bold text-slate-900">为什么选择 星驿付?</h3>
            <p class="mt-4 text-gray-600">我们不仅仅提供硬件，更提供让您省心的全套服务体系。</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {[
              { icon: 'zap', title: "极速到账", desc: "D0/D1灵活结算，365天资金不停歇，让您的资金流转更高效。" },
              { icon: 'shield', title: "金融级安全", desc: "拥有央行颁发的支付牌照，银联认证终端，多重加密保障资金安全。" },
              { icon: 'chart', title: "智慧报表", desc: "多维度交易数据分析，APP实时查看流水，经营状况一目了然。" },
              { icon: 'globe', title: "全渠道聚合", desc: "支持微信、支付宝、云闪付、刷卡、插卡、挥卡等全支付方式。" },
              { icon: 'smartphone', title: "移动便捷", desc: "所有操作均可在手机APP完成，进件、提现、查账，足不出户。" },
              { icon: 'headphones', title: "24/7 客服", desc: "专业的客服团队全天候在线，快速响应解决您在使用中的任何问题。" },
            ].map((feature) => (
              <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-shadow border border-slate-100 group">
                <div class="w-14 h-14 bg-brand-50 rounded-xl flex items-center justify-center text-brand-600 mb-6 group-hover:bg-brand-600 group-hover:text-white transition-colors">
                  {feature.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>}
                  {feature.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>}
                  {feature.icon === 'chart' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>}
                  {feature.icon === 'globe' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>}
                  {feature.icon === 'smartphone' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>}
                  {feature.icon === 'headphones' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14v3a2 2 0 0 0 2 2h2v-5H3z"/><path d="M17 14v5h2a2 2 0 0 0 2-2v-3h-4z"/><path d="M21 12c0-4.97-4.03-9-9-9s-9 4.03-9 9"/></svg>}
                </div>
                <h4 class="text-xl font-bold text-slate-900 mb-3">{feature.title}</h4>
                <p class="text-gray-500 leading-relaxed">{feature.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Product Highlight -->
      <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-end mb-12">
            <div>
              <h2 class="text-3xl font-bold text-slate-900">明星产品</h2>
              <p class="mt-2 text-gray-600">满足不同场景的收银需求</p>
            </div>
            <a href="/products" class="hidden md:flex items-center text-brand-600 font-semibold hover:text-brand-800 transition-colors">
              查看全部 
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {PRODUCTS.slice(0, 4).map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
          
          <div class="mt-8 text-center md:hidden">
            <a href="/products" class="inline-flex items-center text-brand-600 font-semibold">
              查看全部 
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="py-20 bg-brand-800 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
        <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">准备好提升您的收款体验了吗？</h2>
          <p class="text-blue-200 text-lg mb-10">加入500万+商户的选择，开启智能商业新时代。无需复杂申请，极速审核。</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="px-10 py-4 bg-accent-500 text-white rounded-lg font-bold text-lg hover:bg-accent-600 transition-colors shadow-lg">
              免费申请办理
            </a>
            <a href="/about" class="px-10 py-4 bg-transparent border-2 border-blue-400 text-white rounded-lg font-bold text-lg hover:bg-blue-800 hover:border-blue-300 transition-colors">
              联系代理加盟
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
