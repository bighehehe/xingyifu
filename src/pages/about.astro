---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="关于我们 - 星驿付">
  <Navbar />
  <main class="flex-grow pb-8">
    <div class="pt-20 min-h-screen">
       <!-- Hero -->
      <div class="relative bg-brand-900 h-96 flex items-center justify-center overflow-hidden">
        <img src="https://picsum.photos/seed/office/1920/1080" class="absolute inset-0 w-full h-full object-cover opacity-20" alt="Office" />
        <div class="relative z-10 text-center px-4">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">关于 星驿付</h1>
          <p class="text-blue-100 text-xl">科技赋能金融，信用成就未来</p>
        </div>
      </div>

      <!-- Intro -->
      <div class="max-w-4xl mx-auto px-4 py-20 text-center">
        <h2 class="text-3xl font-bold text-slate-900 mb-6">公司简介</h2>
        <p class="text-gray-600 leading-8 text-lg">
          星驿付成立于2010年，是国内领先的第三方支付服务提供商。公司拥有中国人民银行颁发的《支付业务许可证》，业务范围覆盖全国。我们致力于通过技术创新，为中小微商户提供安全、便捷、智能的综合金融服务，构建开放、共享、共赢的支付生态圈。
        </p>
      </div>

      <!-- Culture -->
      <div class="bg-slate-50 py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
             {[
               {icon: 'target', title: "企业使命", desc: "让支付更简单，让商业更智能"},
               {icon: 'users', title: "企业愿景", desc: "成为商户最信赖的数字化合作伙伴"},
               {icon: 'award', title: "核心价值观", desc: "诚信、创新、客户至上、合作共赢"},
               {icon: 'briefcase', title: "经营理念", desc: "合规经营，稳健发展，科技驱动"}
             ].map((item) => (
               <div class="bg-white p-8 rounded-xl shadow-md text-center">
                 <div class="w-16 h-16 mx-auto bg-brand-100 rounded-full flex items-center justify-center text-brand-700 mb-6">
                   {item.icon === 'target' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
                   {item.icon === 'users' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
                   {item.icon === 'award' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>}
                   {item.icon === 'briefcase' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>}
                 </div>
                 <h3 class="text-xl font-bold text-slate-900 mb-2">{item.title}</h3>
                 <p class="text-gray-600">{item.desc}</p>
               </div>
             ))}
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="py-20 max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">发展历程</h2>
        <div class="space-y-12 border-l-4 border-brand-200 ml-4 md:ml-auto md:max-w-3xl pl-8 relative">
          {[
            {year: '2023', title: '数字化升级', desc: '全面布局SaaS服务，发布Star Smart V9。'},
            {year: '2020', title: '逆势增长', desc: '服务商户突破300万，日交易额创新高。'},
            {year: '2016', title: '全国布局', desc: '完成全国30+分公司建设，业务覆盖全境。'},
            {year: '2011', title: '获得牌照', desc: '首批获得央行颁发的《支付业务许可证》。'},
            {year: '2010', title: '公司成立', desc: '星驿付主体公司在上海成立。'}
          ].map((item) => (
             <div class="relative">
               <span class="absolute -left-[41px] top-1 w-5 h-5 bg-brand-600 rounded-full border-4 border-white shadow-sm"></span>
               <div class="flex flex-col md:flex-row gap-2 md:gap-8 items-start md:items-center">
                 <span class="text-2xl font-bold text-brand-600">{item.year}</span>
                 <h3 class="text-xl font-bold text-slate-800">{item.title}</h3>
               </div>
               <p class="text-gray-600 mt-2">{item.desc}</p>
             </div>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
